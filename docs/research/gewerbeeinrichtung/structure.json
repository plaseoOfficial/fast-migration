{\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"hTag\": \"H3\",\n    \"h\": \"Fertigung\",\n    \"hStyle\": {\n     \"fontSize\": \"25px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"25px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"imgs\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2024/03/interior-design-white-icons-07.svg\",\n      \"alt\": \"\",\n      \"nw\": 150,\n      \"nh\": 150\n     }\n    ]\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Moderne Homag-Technik, präzise CNC-Verarbeitung und handwerkliche Qualitätskontrolle sorgen dafür, dass jedes Bauteil exakt passt. Von Einzelmöbeln bis zu kompletten Objekten.\",\n    \"tStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Mehr Infos hier\",\n    \"tStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_