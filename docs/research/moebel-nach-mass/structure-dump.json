le\": {\n     \"fontSize\": \"16px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"28px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"…\",\n    \"textStyle\": {\n     \"fontSize\": \"140px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"0px\",\n     \"letterSpacing\": \"-4px\",\n     \"color\": \"rgb(237, 168, 33)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   }\n  ]\n },\n {\n  \"idx\": 6,\n  \"classes\": \"et_pb_section et_pb_section_6 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgba(203, 191, 181, 0.59)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"57.5938px\",\n   \"57.5938px\"\n  ],\n  \"rowCount\": 2,\n  \"moduleCount\": 5,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Unsere Geschichte – Qualität aus fast drei Jahrzehnten\",\n    \"headingStyle\": {\n     \"fontSize\": \"84px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"84px\",\n     \"letterSpacing\": \"-3px\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"center\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Vom Garagenbetrieb zum modernen Möbelhersteller.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"4px\",\n     \"color\": \"rgb(61, 61, 61)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"center\"\n    }\n   },\n   {\n    \"