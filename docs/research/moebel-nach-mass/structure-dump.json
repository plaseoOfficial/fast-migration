"[\n {\n  \"idx\": 0,\n  \"classes\": \"et_pb_section et_pb_section_0 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgb(255, 255, 255)\",\n  \"bgImage\": \"url(\\\"http://fast.side-boost.com/wp-content/uploads/2025/11/WhatsApp-Bild-2025-04-01-um-22.54.05_fab2d495.jpg\\\")\",\n  \"padding\": [\n   \"249px\",\n   \"57.5938px\"\n  ],\n  \"rowCount\": 1,\n  \"moduleCount\": 3,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H1\",\n    \"heading\": \"Möbel nach Maß aus Espelkamp – millimetergenau geplant\",\n    \"headingStyle\": {\n     \"fontSize\": \"70px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"84px\",\n     \"letterSpacing\": \"-3px\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_module dipi_breadcrumbs dipi_breadcrumbs_0\",\n    \"rawText\": \"fast.side-boost.com $ Leistungen $ Möbel nach Maß\",\n    \"link\": {\n     \"text\": \"fast.side-boost.com\",\n     \"href\": \"http://fast.side-boost.com\",\n     \"cls\": \"\",\n     \"style\": {\n      \"fontSize\": \"15px\",\n      \"fontWeight\": \"500\",\n      \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n      \"lineHeight\": \"26px\",\n      \"letterSpacing\": \"normal\",\n      \"color\": \"rgba(255, 255, 255, 0.7)\",\n      \"textTransform\": \"none\",\n      \"textAlign\": \"start\",\n      \"backgroundColor\": \"rgba(0, 0, 0, 0)\",\n      \"borderRadius\": \"0px\",\n      \"paddingTop\": \"0px\",\n      \"paddingLeft\": \"0px\",\n      \"border\": \"0px solid rgba(255, 255, 255, 0.7)\"\n     }\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"text\": \"Standardlösungen finden Sie in jedem Möbelhaus. Wir bei Fast Systemmöbel gehen einen Schritt weiter: Wir planen und fertigen hochwertige Möbel nach Maß, die sich millimetergenau in Ihre Räume einfügen und Ihre Persönlichkeit perfekt unterstreichen.\",\n    \"textStyle\": {\n     \"fontSize\": \"15px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgba(255, 255, 255, 0.7)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   }\n  ]\n },\n {\n  \"idx\": 1,\n  \"classes\": \"et_pb_section et_pb_section_1 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgba(203, 191, 181, 0.59)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"57.5938px\",\n   \"29px\"\n  ],\n  \"rowCount\": 3,\n  \"moduleCount\": 11,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H4\",\n    \"heading\": \"seit 1996\",\n    \"headingStyle\": {\n     \"fontSize\": \"30px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"30px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgba(117, 117, 117, 0.5)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Geben wir unser Bestes.\",\n    \"textStyle\": {\n     \"fontSize\": \"16px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"16px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgba(117, 117, 117, 0.5)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Individuelle Möbel nach Maß für jeden Raum präzise planen\",\n    \"headingStyle\": {\n     \"fontSize\": \"66px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"66px\",\n     \"letterSpacing\": \"-3px\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"text\": \"Fast Systemmöbel aus Espelkamp begleitet Sie genau in dieser entscheidenden Bauphase. Mit präziser Planung, ehrlicher Beratung und handwerklicher Umsetzung, die jeden Quadratmeter nutzt.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"28.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Maßarbeit planen\",\n    \"headingStyle\": {\n     \"fontSize\": \"20px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"20px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(51, 51, 51)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Wir fertigen Möbel nach Maß, die millimetergenau zu Ihrem Raum passen und jede Nische optimal nutzen. Jede Maßanfertigung entsteht individuell nach Ihren Anforderungen. Mit hochwertigen Dekoren, stabilen Konstruktionen und präzisem Aufmaß-Service.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_button\",\n    \"rawText\": \"Jetzt individuelle Anfrage stellen\",\n    \"link\": {\n     \"text\": \"Jetzt individuelle Anfrage stellen\",\n     \"href\": \"/kontakt\",\n     \"cls\": \"et_pb_button et_pb_button_0 et_pb_bg_layout_light\",\n     \"style\": {\n      \"fontSize\": \"20px\",\n      \"fontWeight\": \"500\",\n      \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n      \"lineHeight\": \"34px\",\n      \"letterSpacing\": \"normal\",\n      \"color\": \"rgb(0, 0, 0)\",\n      \"textTransform\": \"none\",\n      \"textAlign\": \"start\",\n      \"backgroundColor\": \"rgba(255, 255, 255, 0)\",\n      \"borderRadius\": \"0px\",\n      \"paddingTop\": \"0px\",\n      \"paddingLeft\": \"0px\",\n      \"border\": \"0px solid rgb(0, 0, 0)\"\n     }\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Dabei planen wir jedes Möbelstück so, dass Funktionalität, Stauraum und Alltagstauglichkeit perfekt zusammenspielen. Ob Schrank, Regal, Sideboard oder Kommode: Sie erhalten maßgeschneiderte Möbel, die langlebig gebaut, modern gestaltet und sauber integriert werden – exakt nach Ihren Vorstellungen.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"dipi_counter\",\n    \"rawText\": \"72K+\"\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"gefertigte Einzelteile\",\n    \"headingStyle\": {\n     \"fontSize\": \"31px\",\n     \"fontWeight\": \"600\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31px\",\n     \"letterSpacing\": \"-1px\",\n     \"color\": \"rgb(51, 51, 51)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Unsere Fertigung kombiniert neueste CNC-Technik mit handwerklicher Perfektion.So entstehen Systemmöbel, die langlebig, funktional und ästhetisch überzeugen – in jedem Projekt, jedem Detail.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_button\",\n    \"rawText\": \"Entdecken Sie das Gefühl von Qualität\",\n    \"link\": {\n     \"text\": \"Entdecken Sie das Gefühl von Qualität\",\n     \"href\": \"http://fast.side-boost.com/project/mixmarkt/\",\n     \"cls\": \"et_pb_button et_pb_button_1 et_pb_bg_layout_light\",\n     \"style\": {\n      \"fontSize\": \"20px\",\n      \"fontWeight\": \"500\",\n      \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n      \"lineHeight\": \"34px\",\n      \"letterSpacing\": \"normal\",\n      \"color\": \"rgb(0, 0, 0)\",\n      \"textTransform\": \"none\",\n      \"textAlign\": \"start\",\n      \"backgroundColor\": \"rgba(255, 255, 255, 0)\",\n      \"borderRadius\": \"0px\",\n      \"paddingTop\": \"0px\",\n      \"paddingLeft\": \"0px\",\n      \"border\": \"0px solid rgb(0, 0, 0)\"\n     }\n    }\n   },\n   {\n    \"type\": \"dipi_expanding_cta\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Maßmöbel nach Ihren Vorstellungen\",\n    \"headingStyle\": {\n     \"fontSize\": \"65px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"71.5px\",\n     \"letterSpacing\": \"-2px\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"link\": {\n     \"text\": \"Sprechen Sie mit uns über Ihr Projekt\",\n     \"href\": \"/kontakt\",\n     \"cls\": \"et_pb_button dipi_content_button\",\n     \"style\": {\n      \"fontSize\": \"20px\",\n      \"fontWeight\": \"500\",\n      \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n      \"lineHeight\": \"34px\",\n      \"letterSpacing\": \"normal\",\n      \"color\": \"rgb(255, 255, 255)\",\n      \"textTransform\": \"none\",\n      \"textAlign\": \"left\",\n      \"backgroundColor\": \"rgba(255, 255, 255, 0)\",\n      \"borderRadius\": \"0px\",\n      \"paddingTop\": \"0px\",\n      \"paddingLeft\": \"0px\",\n      \"border\": \"0px solid rgb(255, 255, 255)\"\n     }\n    }\n   }\n  ]\n },\n {\n  \"idx\": 2,\n  \"classes\": \"et_pb_section et_pb_section_2 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgba(203, 191, 181, 0.59)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"46px\",\n   \"57.5938px\"\n  ],\n  \"rowCount\": 1,\n  \"moduleCount\": 3,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Planung, Fertigung und Montage für Maßmöbel aus einer Hand\",\n    \"headingStyle\": {\n     \"fontSize\": \"59px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"59px\",\n     \"letterSpacing\": \"-4px\",\n     \"color\": \"rgb(23, 33, 33)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Unsere Maßmöbel entstehen in einem strukturierten Prozess: digitales Planen, professionelles Aufmaß, Fertigung auf Homag-Technologie und saubere Montage durch unser eigenes Team. Dabei kombinieren wir hochwertige Materialien, moderne Dekore und robuste Konstruktionen für maximale Funktionalität. Ob Schrank nach Maß, Regal, Sideboard, Kommode oder Lösungen für Nischen und Dachschrägen – wir entwick\",\n    \"textStyle\": {\n     \"fontSize\": \"16px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"28px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"…\",\n    \"textStyle\": {\n     \"fontSize\": \"140px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"0px\",\n     \"letterSpacing\": \"-4px\",\n     \"color\": \"rgb(237, 168, 33)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"right\"\n    }\n   },\n   {\n    \"type\": \"et_pb_image\",\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2025/11/20161103_150622294_iOS-scaled.jpg\",\n      \"alt\": \"\",\n      \"w\": 2560,\n      \"h\": 1920\n     }\n    ]\n   }\n  ]\n },\n {\n  \"idx\": 3,\n  \"classes\": \"et_pb_section et_pb_section_3 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgba(203, 191, 181, 0.59)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"72px\",\n   \"73px\"\n  ],\n  \"rowCount\": 3,\n  \"moduleCount\": 19,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Leisten? Immer 100% – wir fertigen Sie aber auch\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(61, 61, 61)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"center\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Weitere Leistungen von Fast Systemmöbel\",\n    \"headingStyle\": {\n     \"fontSize\": \"80px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"80px\",\n     \"letterSpacing\": \"-2px\",\n     \"color\": \"rgb(61, 61, 61)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"center\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Möbel nach Maß\",\n    \"headingStyle\": {\n     \"fontSize\": \"25px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"25px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2024/03/interior-design-white-icons-15.svg\",\n      \"alt\": \"\",\n      \"w\": 150,\n      \"h\": 150\n     }\n    ]\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Jedes Stück ein Unikat. Ob Küche, Bad oder Wohnraum: Wir fertigen passgenaue Möbel, die sich exakt nach Ihrem Stil, Ihrem Alltag und Ihrem Raum richten.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Mehr Infos hier\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Raumkonzepte\",\n    \"headingStyle\": {\n     \"fontSize\": \"25px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"25px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2024/03/interior-design-white-icons-22.svg\",\n      \"alt\": \"\",\n      \"w\": 150,\n      \"h\": 150\n     }\n    ]\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Wir denken Räume ganzheitlich. Durchdachte Konzepte verbinden Architektur, Licht, Materialien und Möbel zu einer harmonischen Einheit – vom ersten Entwurf bis zur Montage.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Mehr Infos hier\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Fertigung\",\n    \"headingStyle\": {\n     \"fontSize\": \"25px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"25px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2024/03/interior-design-white-icons-07.svg\",\n      \"alt\": \"\",\n      \"w\": 150,\n      \"h\": 150\n     }\n    ]\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Moderne Homag-Technik, präzise CNC-Verarbeitung und handwerkliche Qualitätskontrolle sorgen dafür, dass jedes Bauteil exakt passt. Von Einzelmöbeln bis zu kompletten Objekten.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Mehr Infos hier\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Objekt- & Gewerbeeinrichtung\",\n    \"headingStyle\": {\n     \"fontSize\": \"25px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"25px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2024/03/interior-design-white-icons-08.svg\",\n      \"alt\": \"\",\n      \"w\": 150,\n      \"h\": 150\n     }\n    ]\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Für Hotels, Büros oder Ladengeschäfte entwickeln wir langlebige Möbelkonzepte, die Design und Funktion vereinen. Robust, zeitlos und auf das Nutzungskonzept abgestimmt.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Mehr Infos hier\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Montage\",\n    \"headingStyle\": {\n     \"fontSize\": \"25px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"25px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2024/03/interior-design-white-icons-09.svg\",\n      \"alt\": \"\",\n      \"w\": 150,\n      \"h\": 150\n     }\n    ]\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Unsere Monteure arbeiten sauber, termingerecht und millimetergenau. Die finale Passung wird vor Ort abgestimmt – bis jedes Detail sitzt.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Mehr infos hier\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"2px\",\n     \"color\": \"rgb(243, 243, 243)\",\n     \"textTransform\": \"uppercase\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"&\",\n    \"textStyle\": {\n     \"fontSize\": \"300px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"300px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\",\n    \"text\": \"Jedes Projekt entsteht bei uns aus Erfahrung, Planungssicherheit und moderner Fertigung. Ob Einzelstück oder kompletter Innenausbau – Sie profitieren von Lösungen, die langfristig tragen und handwerklich sauber umgesetzt sind.\",\n    \"textStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"31.5px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(23, 33, 33)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   }\n  ]\n },\n {\n  \"idx\": 4,\n  \"classes\": \"et_pb_section et_pb_section_4 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgba(203, 191, 181, 0.59)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"57.5938px\",\n   \"57.5938px\"\n  ],\n  \"rowCount\": 2,\n  \"moduleCount\": 9,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Typische Maßanfertigungen – passgenaue Möbel für Ihr Zuhause\",\n    \"headingStyle\": {\n     \"fontSize\": \"64px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"64px\",\n     \"letterSpacing\": \"-3px\",\n     \"color\": \"rgb(23, 33, 33)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\"\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Küchen\",\n    \"headingStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"18px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Klare Linien, funktionale Wege, perfekt integrierte Stauraumlösungen für jeden Küchenraum.\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Bad\",\n    \"headingStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"18px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Präzise Planung für kleine und große Bäder: Stauraum, Lichtführung und harmonische Materialien.\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Garderoben\",\n    \"headingStyle\": {\n     \"fontSize\": \"20px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"20px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Durchdachte Garderoben mit optimaler Aufteilung für Alltag, Familie und saisonale Ordnung.\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Wohnbereiche\",\n    \"headingStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"18px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Wohnräume, die Struktur geben: Möbel, Akzente und Proportionen mit klarer Wirkung.\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Homeoffice\",\n    \"headingStyle\": {\n     \"fontSize\": \"18px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"18px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Arbeitsbereiche, die Ruhe, Ergonomie und Stauraum verbinden – auch auf kleinsten Flächen.\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_blurb\",\n    \"headingTag\": \"H3\",\n    \"heading\": \"Stauraum\",\n    \"headingStyle\": {\n     \"fontSize\": \"20px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"20px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(0, 0, 0)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Individuelle Lösungen, die jeden Zentimeter nutzen – für Nischen, Dachschrägen und Sonderbereiche.\",\n    \"textStyle\": {\n     \"fontSize\": \"14px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(102, 102, 102)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   },\n   {\n    \"type\": \"et_pb_text\"\n   }\n  ]\n },\n {\n  \"idx\": 5,\n  \"classes\": \"et_pb_section et_pb_section_5 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgba(203, 191, 181, 0.59)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"46px\",\n   \"57.5938px\"\n  ],\n  \"rowCount\": 1,\n  \"moduleCount\": 3,\n  \"modules\": [\n   {\n    \"type\": \"dipi_masonry_gallery\",\n    \"images\": [\n     {\n      \"src\": \"http://fast.side-boost.com/wp-content/uploads/2025/11/20231204_095459232_iOS-scaled.jpg\",\n      \"alt\": \"Moderne Küche in Grau und Weiß mit\",\n  