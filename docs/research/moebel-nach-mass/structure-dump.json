pb_blurb\",\n    \"text\": \"– Made in Germany– 1.000 m² Fertigung– Meisterbetrieb seit 2013– Homag-Technologie– Aufbau bis 200 km– Lieferung bundesweit\",\n    \"textStyle\": {\n     \"fontSize\": \"16px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"23.8px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    }\n   }\n  ]\n },\n {\n  \"idx\": 7,\n  \"classes\": \"et_pb_section et_pb_section_7 et_pb_with_background et_section_regular\",\n  \"bgColor\": \"rgb(61, 61, 61)\",\n  \"bgImage\": null,\n  \"padding\": [\n   \"46px\",\n   \"0px\"\n  ],\n  \"rowCount\": 1,\n  \"moduleCount\": 3,\n  \"modules\": [\n   {\n    \"type\": \"et_pb_text\",\n    \"headingTag\": \"H2\",\n    \"heading\": \"Möbel nach Maß einfach online planen und konfigurieren\",\n    \"headingStyle\": {\n     \"fontSize\": \"64px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"64px\",\n     \"letterSpacing\": \"-4px\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\",\n     \"textAlign\": \"left\"\n    },\n    \"text\": \"Mit unserem Möbelkonfigurator können Sie Ihre Möbel nach Maß online planen – schnell, übersichtlich und millimetergenau. Ob Schrank nach Maß, Regal, Sideboard oder Kommode: Sie konfigurieren Maße, Dekore, Einlegeböden oder Schubladen bequem von zuhause. Der 3D-Konfigurator zeigt jede Anpassung sofort an und macht individuelle Möbel nach Maß für Sie direkt sichtbar. Nach der Konfiguration übernehme\",\n    \"textStyle\": {\n     \"fontSize\": \"16px\",\n     \"fontWeight\": \"500\",\n     \"fontFamily\": \"Urbanist, Helvetica, Arial, Lucida, sans-serif\",\n     \"lineHeight\": \"28px\",\n     \"letterSpacing\": \"normal\",\n     \"color\": \"rgb(255, 255, 255)\",\n     \"textTransform\": \"none\"